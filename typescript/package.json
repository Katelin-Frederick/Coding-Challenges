{
    "name": "coding_challenges_typescript",
    "version": "1.0.0",
    "description": "Coding Challenges using Typescript",
    "main": "index.js",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "git config core.hooksPath typescript/.husky"
    },
    "lint-staged": {
        "*.{ts}": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "author": "Katelin Frederick",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jest": "^29.5.14",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^16.3.3",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    }
}
